{
  "name": "mentions-matcher",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    { "binding": "DB", "database_name": "mentions", "database_id": "d7544f01-aeb7-4d49-903e-821cf0244f64" }
  ],
  "kv_namespaces": [{ "binding": "KV", "id": "563524d26a444c0ca62c88b9616065c6" }],
  "queues": {
    "consumers": [
      { "queue": "mentions-raw-items", "max_batch_size": 20, "max_concurrency": 4 }
    ],
    "producers": [{ "binding": "CLASSIFY", "queue": "mentions-classify" }]
  },
  "observability": { "enabled": true }
}
